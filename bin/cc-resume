#!/usr/bin/env python3
"""
cc-resume — interactive Claude Code session picker + resume.

Uses fzf to browse recent sessions with a live preview pane showing each
session's opening and last prompts. On selection, cd into the session's cwd
and exec `claude --resume <session_id>`.

Pass-through args go to `cc-recent` (e.g. `cc-resume --days 7 --project tao`).
"""
from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import tempfile

CC_RECENT = "cc-recent"
PREVIEW_CHAR_LIMIT = 350


def check(name: str) -> bool:
    return shutil.which(name) is not None


def fmt_tokens(n: int) -> str:
    """Format token count as compact K string with commas. 285120→'285K', 10014000→'10,014K', 0→'—'."""
    if n <= 0:
        return "—"
    if n >= 10_000:
        return f"{n // 1000:,}K"
    if n >= 1_000:
        return f"{n / 1000:.1f}K"
    return str(n)


def trim(txt: str, limit: int = PREVIEW_CHAR_LIMIT) -> str:
    """Collapse whitespace and truncate to `limit` chars, appending `…` if cut."""
    one = (txt or "").replace("\n", " ").replace("\r", " ")
    if len(one) <= limit:
        return one
    return one[: max(0, limit - 1)] + "…"


def _is_wide_char(ch: str) -> bool:
    o = ord(ch)
    return (
        0x1100 <= o <= 0x115F
        or 0x2E80 <= o <= 0x303E
        or 0x3041 <= o <= 0x33FF
        or 0x3400 <= o <= 0x4DBF
        or 0x4E00 <= o <= 0x9FFF
        or 0xA000 <= o <= 0xA4CF
        or 0xAC00 <= o <= 0xD7A3
        or 0xF900 <= o <= 0xFAFF
        or 0xFE30 <= o <= 0xFE4F
        or 0xFF00 <= o <= 0xFF60
        or 0xFFE0 <= o <= 0xFFE6
    )


def display_width(s: str) -> int:
    return sum(2 if _is_wide_char(c) else 1 for c in s)


def trim_display(txt: str, max_w: int) -> str:
    """Truncate to max display columns (CJK-aware), appending `…` if cut."""
    one = (txt or "").replace("\n", " ").replace("\r", " ")
    if display_width(one) <= max_w:
        return one
    out: list[str] = []
    w = 0
    for ch in one:
        cw = 2 if _is_wide_char(ch) else 1
        if w + cw > max_w - 1:
            break
        out.append(ch)
        w += cw
    return "".join(out) + "…"


def pad_display(s: str, target_w: int) -> str:
    w = display_width(s)
    if w >= target_w:
        return s
    return s + (" " * (target_w - w))


def volume_marker(total_msgs: int) -> str:
    """1-char marker for conversation weight — matches cc-sessions.py thresholds."""
    if total_msgs < 20:
        return " "
    if total_msgs < 50:
        return "·"
    if total_msgs < 150:
        return "●"
    return "◉"


def render_box(s: dict) -> str:
    """Render one session as a labeled box — mirrors cc-sessions.py layout."""
    width = 72
    bar = "─" * width
    lines = [f"┌{bar}"]
    lines.append(f"│ 📁 project:     {s.get('project', '?')}")
    lines.append(f"│ session id:     {s.get('session_id', '?')}")
    lines.append(f"│ started:        {(s.get('first_ts') or '?')[:19].replace('T', ' ')}")
    lines.append(f"│ last activity:  {(s.get('last_ts') or '?')[:19].replace('T', ' ')}")
    lines.append(f"│ cwd:            {s.get('cwd') or '(none)'}")
    lines.append(f"│ branch:         {s.get('branch') or '(none)'}")
    lines.append(
        f"│ messages:       assistant {s.get('asst_count', 0)} / user {s.get('user_count', 0)}"
    )
    if s.get("forked_from"):
        lines.append(f"│ forked from:    {s.get('forked_from')}")
    if s.get("plan_title"):
        lines.append(f"│ plan:           {s.get('plan_title')}")
    # Token usage breakdown
    tok = s.get("tokens") or {}
    total_in = tok.get("total_input", 0)
    turn_count = tok.get("turn_count", 0)
    if turn_count > 0:
        cache_hit = round(tok.get("cache_read", 0) / total_in * 100) if total_in > 0 else 0
        avg_in = total_in // turn_count
        lines.append(f"│ ── tokens ──")
        lines.append(f"│ input:          {total_in:>10,}    (cache hit {cache_hit}%)")
        lines.append(f"│ output:         {tok.get('total_output', 0):>10,}")
        lines.append(
            f"│ cache:          {fmt_tokens(tok.get('cache_read', 0))} read / "
            f"{fmt_tokens(tok.get('cache_create', 0))} created"
        )
        lines.append(f"│ avg input/turn: {avg_in:>10,}")
    lines.append(f"├{bar}")
    prompts = s.get("prompts") or []
    lines.append("│ opening prompts")
    for i, p in enumerate(prompts[:3], 1):
        lines.append(f"│  [{i}] {trim(p.get('text', ''))}")
    # Dedupe: last-2 can overlap with opening-3 on short sessions
    opening_ids = {id(p) for p in prompts[:3]}
    last_two = [p for p in prompts[-2:] if id(p) not in opening_ids]
    if last_two:
        lines.append("│")
        lines.append("│ last prompts")
        for i, p in enumerate(last_two, 1):
            lines.append(f"│  [{i}] {trim(p.get('text', ''))}")
    lines.append(f"└{bar}")
    return "\n".join(lines)


def preview_mode(preview_dir: str, session_id: str) -> int:
    """Print a session box — called internally by fzf --preview."""
    path = os.path.join(preview_dir, f"{session_id}.txt")
    try:
        with open(path, "r") as f:
            sys.stdout.write(f.read())
        return 0
    except FileNotFoundError:
        print(f"(preview not found: {session_id})", file=sys.stderr)
        return 1


def main() -> int:
    # Internal preview hook
    if len(sys.argv) >= 4 and sys.argv[1] == "--preview-for":
        return preview_mode(preview_dir=sys.argv[2], session_id=sys.argv[3])

    # Dependency checks
    if not check("fzf"):
        print("error: fzf not found. install with: brew install fzf", file=sys.stderr)
        return 2
    if not check(CC_RECENT):
        print(f"error: {CC_RECENT} not found in PATH", file=sys.stderr)
        return 2
    if not check("claude"):
        print("warning: 'claude' not found in PATH — resume will fail", file=sys.stderr)

    # Pass-through extra args to cc-recent
    extra = sys.argv[1:]
    cmd = [CC_RECENT, "--json", *extra]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"error: {CC_RECENT} failed:\n{result.stderr}", file=sys.stderr)
        return result.returncode

    try:
        sessions = json.loads(result.stdout)
    except json.JSONDecodeError as e:
        print(f"error: failed to parse JSON from {CC_RECENT}: {e}", file=sys.stderr)
        return 3

    if not sessions:
        print(
            "No sessions found. Try: cc-resume --days 7   or   cc-resume --all",
            file=sys.stderr,
        )
        return 0

    # Use a persistent tempdir for the duration of fzf + selection
    preview_dir = tempfile.mkdtemp(prefix="cc-resume-")
    try:
        # Pre-render all previews to files
        for s in sessions:
            sid = s.get("session_id")
            if not sid:
                continue
            with open(os.path.join(preview_dir, f"{sid}.txt"), "w") as f:
                f.write(render_box(s))

        # Build fzf input — tab-separated fields
        # Columns (1-indexed for fzf):
        #   1=last, 2=project, 3=markers (vol+fork), 4=in(tok), 5=sid, 6=cwd, 7=first_prompt
        lines = []
        for s in sessions:
            last = (s.get("last_ts") or "")[:19].replace("T", " ")
            # Drop year prefix "YYYY-"
            if len(last) >= 10 and last[4] == "-":
                last = last[5:]
            proj = (s.get("project") or "?")[:25]
            sid = s.get("session_id") or "?"
            cwd = s.get("cwd") or ""
            vol = volume_marker(s.get("asst_count", 0) + s.get("user_count", 0))
            fork = "↳" if s.get("forked_from") else " "
            markers = f"{vol} {fork}"  # fixed 3-char column
            tok = s.get("tokens") or {}
            tok_col = f"{fmt_tokens(tok.get('total_input', 0)):>9}"
            prompts = s.get("prompts") or []
            # First prompt is the primary label. Plan title becomes a second
            # column, aligned via CJK-aware padding + visible │ separator.
            first_raw = prompts[0].get("text", "") if prompts else ""
            first_col = pad_display(trim_display(first_raw, 80), 80)
            plan_title = s.get("plan_title") or ""
            plan_col = trim_display(plan_title, 50) if plan_title else ""
            label = f"{first_col}  {plan_col}" if plan_col else first_col
            lines.append(f"{last}\t{proj:<25}\t{markers}\t{tok_col}\t{sid}\t{cwd}\t{label}")
        fzf_input = "\n".join(lines)

        # fzf preview: re-invoke this script with --preview-for
        script_path = os.path.abspath(sys.argv[0])
        preview_cmd = f"{script_path!r} --preview-for {preview_dir!r} {{5}}"
        fzf_args = [
            "fzf",
            "--ansi",
            "--delimiter=\t",
            # Show: last, project, markers, in(tok), first_prompt (hide sid=5 and cwd=6)
            "--with-nth=1,2,3,4,7",
            "--preview", preview_cmd,
            "--preview-window=down:65%:wrap:border-top",
            "--header=↑↓ browse · ·/●/◉=volume · ↳=forked · Enter=resume · Esc=cancel",
            "--prompt=session> ",
            "--height=95%",
            "--border",
        ]
        try:
            proc = subprocess.run(
                fzf_args, input=fzf_input, text=True, capture_output=True
            )
        except KeyboardInterrupt:
            return 130

        # fzf exit codes: 0=selected, 1=no match, 2=error, 130=cancelled
        if proc.returncode == 130 or not proc.stdout.strip():
            return 0  # user cancelled
        if proc.returncode not in (0, 1):
            print(f"fzf error: {proc.stderr}", file=sys.stderr)
            return proc.returncode

        selected = proc.stdout.strip().split("\n")[0]
        fields = selected.split("\t")
        # Fields: 0=last, 1=project, 2=markers, 3=in(tok), 4=sid, 5=cwd, 6=first_prompt
        if len(fields) < 6:
            print(f"error: unexpected fzf output: {selected!r}", file=sys.stderr)
            return 4
        session_id = fields[4].strip()
        cwd = fields[5].strip()
    finally:
        shutil.rmtree(preview_dir, ignore_errors=True)

    if not session_id:
        print("error: no session id in selection", file=sys.stderr)
        return 5

    # cd into session's original cwd (if possible) and exec claude --resume
    if cwd and os.path.isdir(cwd):
        os.chdir(cwd)
    elif cwd:
        print(f"warning: cwd not accessible, running from current dir: {cwd}", file=sys.stderr)

    print(f"resuming {session_id} from {os.getcwd()}", file=sys.stderr)
    try:
        os.execvp("claude", ["claude", "--resume", session_id])
    except FileNotFoundError:
        print("error: 'claude' command not found in PATH", file=sys.stderr)
        return 127


if __name__ == "__main__":
    sys.exit(main())
